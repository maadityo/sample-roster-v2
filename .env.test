# Environment variables for running automated tests locally.
# Used by Vitest (API tests) and Playwright (E2E tests).
# Copy this file to .env.test.local to override values without committing secrets.

# Separate test database — keeps test data isolated from your dev DB.
# Make sure to create it first:
#   docker exec kakak-db createdb -U kakak kakak_test
DATABASE_URL="postgresql://kakak:kakak_secret@localhost:5432/kakak_test?schema=public"

# NextAuth — any fixed value works for testing.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="test-secret-not-for-production-do-not-use-in-prod"

# Enables the /api/test/login bypass endpoint used by Playwright auth setup.
NEXTAUTH_TEST_MODE="true"

# App limits (mirror your production values).
MAX_ABSENCES_PER_MONTH=2
MAX_ABSENCES_PER_SUNDAY=3
