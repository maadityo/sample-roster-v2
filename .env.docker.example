# ─────────────────────────────────────────────────────────────────
# Kakak App — Environment Variables
# Copy file ini ke .env lalu isi nilainya
#
# PRODUCTION: cukup set AZURE_KEY_VAULT_URL, sisanya otomatis dari KV
# LOCAL DEV : isi bagian "Fallback" di bawah (tanpa Key Vault)
# ─────────────────────────────────────────────────────────────────

# ── Azure Key Vault ───────────────────────────────────────────────
# Jika di-set, secret diambil otomatis dari KV saat server start
AZURE_KEY_VAULT_URL=https://akv-prod-eau-01.vault.azure.net/

# Client ID dari User Managed Identity (umi-kakak-prod-01)
# Ambil dari: az identity show --name umi-kakak-prod-01 --query clientId -o tsv
AZURE_CLIENT_ID=

# ── Secrets dari Key Vault (tidak perlu diisi jika KV aktif) ─────
#
#   KV secret name        → env var yang di-set
#   sc-nextauth-kakak-sec → NEXTAUTH_SECRET
#   sc-goauth-client-id   → GOOGLE_CLIENT_ID
#   sc-goauth-client-sc   → GOOGLE_CLIENT_SECRET
#   sc-db-kakak-ep        → bagian dari DATABASE_URL (hostname)
#   sc-kakak-db-user      → bagian dari DATABASE_URL (username)
#   sc-kakak-db-pass      → bagian dari DATABASE_URL (password)
#
# Isi di bawah ini HANYA jika local dev tanpa Key Vault:
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DATABASE_URL=postgresql://kakak:kakak_secret@db:5432/kakak?schema=public

# ── App Config (bukan secret, aman di env) ────────────────────────
NEXTAUTH_URL=http://localhost:3000
MAX_ABSENCES_PER_MONTH=2
MAX_ABSENCES_PER_SUNDAY=3
